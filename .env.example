# Gram Nirikshan Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=Gram Nirikshan API
APP_VERSION=1.0.0
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production

# ── Database (MySQL on Hostinger) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gram_nirikshan
DB_USER=gram_user
DB_PASSWORD=your-strong-db-password

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OTP / SMS (MSG91) ──────────────────────────────────────────────────────────
# Get your API key from https://msg91.com
SMS_API_KEY=your-msg91-api-key
SMS_SENDER_ID=GRNKSH
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# ── Google Maps ────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@gramnirikshan.in
SMTP_FROM_NAME=Gram Nirikshan App

# ── File Storage ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000", "https://gramnirikshan.in"]

# ── Department Info ────────────────────────────────────────────────────────────
DEPARTMENT_NAME=ग्राम पंचायत विभाग
DEPARTMENT_NAME_EN=Gram Panchayat Department
